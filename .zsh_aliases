alias ll="ls -la --color"

alias notes="vim ~/Dropbox/Documents/vimwiki/index.wiki"

alias gbranch="git rev-parse --abbrev-ref HEAD | tr -d '\n'"
alias gu="git status"
alias guu="git status -uno"
alias glog="git log --stat"
alias glogp="git log -p"
alias gpushf="git push --force-with-lease"
alias gpusho="git push -u origin \$(gbranch)"
alias gdiff="git diff"

alias gg='cd `git rev-parse --show-toplevel`'
alias gcheckpoint="git add . && git commit -m 'WIP'"
alias grmaster="git checkout master && git pull && git checkout - && git rebase master"
alias grmain="git checkout main && git pull && git checkout - && git rebase main"
# alias gref="git rev-parse --short HEAD | tr -d '\n' | xsel -bi"
# alias gmes="git log -1 --pretty=%B | xsel -bi"
alias stripe-hooks="stripe listen --forward-to http://localhost:3000/events/stripe"
alias bx="bundle exec"
alias nr="npm run"

alias devc="docker exec -it \$(devcontainer exec hostname) zsh"
alias dl='docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Status}}"'
alias dc='docker compose'

if [[ -f /.dockerenv ]]; then
  # this will only execute if we're in a container
else
  # outside of container

  alias heroclistag='herocli --server hero2.staging.ehrocks.com:443'
  alias herocliprod='herocli --server hero2.ehrocks.com:443'
  alias herocliint='herocli --server hero2.integration.ehrocks.com:443'
fi

function dsh () {
  if [ $# -eq 0 ]; then
      echo "No arguments provided. Usage: dsh [SERVICE_NAME]"
      return 1
  fi

  docker compose exec -it "$1" zsh;
}

function srep () {
  if [ $# -eq 0 ]; then
      echo "No arguments provided. Usage: srep [SEARCH_PATTERN] [REPLACE_PATTERN]"
      return 1
  fi

  $FZF_DEFAULT_COMMAND | xargs sed -i "s/$1/$2/g";
}

function gri () {
  if [ $# -eq 0 ]; then
      echo "No arguments provided. Usage: gri [NUMBER_OF_COMMITS]"
      return 1
  fi

  git rebase -i HEAD~"$1";
}

git() {
  if [[ "$1" == "rebase" ]]; then
    echo "⚠️ WARNING: You are about to run 'git rebase'."
    echo -n "Are you sure you want to proceed? (y/N): "
    read -r response

    if [[ "$response" =~ ^[Yy]$ ]]; then
      command git "$@"
    else
      echo "🚫 Rebase aborted."
      return 1
    fi
  else
    # Pass all other git commands through normally
    command git "$@"
  fi
}